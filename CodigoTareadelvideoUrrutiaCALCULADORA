    private void jbtnSumActionPerformed(java.awt.event.ActionEvent evt) {                                        
        // TODO add your handling code here:
        if (!entrada.equals("")) {
        double numero2 = Double.parseDouble(entrada);
        
        if (operador != null && !operador.equals("")) {
            if (operador.equals("+")) { numero1 = numero1 + numero2; }
            else if (operador.equals("-")) { numero1 = numero1 - numero2; }
            else if (operador.equals("*")) { numero1 = numero1 * numero2; }
            else if (operador.equals("/")) { numero1 = numero1 / numero2; }
            jTextField1.setText(String.valueOf(numero1));
        } else {
            numero1 = numero2;
        }
        
        entrada = ""; 
        operador = "+"; 
    }
    }                                       

    private void jbtnIguActionPerformed(java.awt.event.ActionEvent evt) {                                        
        // TODO add your handling code here:
        numero2 = Double.parseDouble(entrada);
        double resultado = 0;
        switch(operador) {
            case "+":
                resultado = numero1 + numero2;
                break;
            case "x":
                resultado = numero1 * numero2;
                break;
            case "-":
                resultado = numero1 - numero2;
                break;
            case "/":
                if(numero2 != 0) {
                    resultado = numero1 / numero2;
                } else {
                    jTextField1.setText("Error");
                    return;
                }
                break;
            case "raiz":
                if(numero1 >= 0) {
                    resultado = Math.sqrt(numero1);
                } else {
                    jTextField1.setText("Error");
                    return;
                }
                break;
        }
        entrada = String.valueOf(resultado);
        jTextField1.setText(entrada);

    }                                       

